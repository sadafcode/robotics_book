{
  "version": 2,
  "framework": null,
  "builds": [
    {
      "src": "auth-service/index.js",
      "use": "@vercel/node",
      "config": {
        "maxDuration": 10
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "auth-service/index.js"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
